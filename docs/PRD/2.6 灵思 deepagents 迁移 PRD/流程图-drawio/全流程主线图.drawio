          <mxGeometry x="330" y="540" width="240" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="F3" value="§4.3 执行过程可视化&lt;br&gt;规划→子任务委派→执行&lt;br&gt;含产物交付·长任务后台运行" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
