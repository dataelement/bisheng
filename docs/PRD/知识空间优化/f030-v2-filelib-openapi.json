{
  "openapi": "3.1.0",
  "info": {
    "title": "BiSheng v2 filelib — 知识资源统一对外 API (F030)",
    "version": "2.6.0",
    "description": "F030 改动的 /api/v2/filelib 接口子集（列表/创建/更新/检索/上传/文件列表/删除/清空）。按 type 或 row.type 在文档知识库(0)/QA库(1)/知识空间(3)间分派；type=2 不对外暴露。列表与文件列表为 cursor 分页（PageInfiniteCursorData，无 total）。"
  },
  "servers": [
    {
      "url": "/",
      "description": "BiSheng backend"
    }
  ],
  "paths": {
    "/api/v2/filelib/": {
      "post": {
        "tags": [
          "OpenAPI",
          "Knowledge"
        ],
        "summary": "Create",
        "description": "Create a knowledge resource (F030 facade, dispatch by ``type``).\n\ntype 0/1 → 文档 / QA 知识库（KnowledgeService）；type 3 → 知识空间\n（KnowledgeSpaceService，忽略 model，用 workbench embedding）；type 2 / 非法 → 不支持。",
        "operationId": "create_api_v2_filelib__post",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/KnowledgeCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": [
          "OpenAPI",
          "Knowledge"
        ],
        "summary": "Update Knowledge",
        "description": "Update name/description of a knowledge resource (F030, dispatch by row.type).",
        "operationId": "update_knowledge_api_v2_filelib__put",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/KnowledgeUpdate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      },
      "get": {
        "tags": [
          "OpenAPI",
          "Knowledge"
        ],
        "summary": "Get Knowledge",
        "description": "List knowledge resources by ``type`` (F030 cursor pagination, INV-6).\n\nParams align with v1 ``GET /api/v1/knowledge``. ``user_id`` scopes the list\nto that user's visibility; omit to use the default operator (AD-02).\nResponse is ``PageInfiniteCursorData`` (data/page_size/has_more/next_cursor).",
        "operationId": "get_knowledge_api_v2_filelib__get",
        "parameters": [
          {
            "name": "type",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 0,
              "title": "Type"
            }
          },
          {
            "name": "name",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Name"
            }
          },
          {
            "name": "sort_by",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "update_time",
              "title": "Sort By"
            }
          },
          {
            "name": "page_size",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "integer"
                },
                {
                  "type": "null"
                }
              ],
              "default": 10,
              "title": "Page Size"
            }
          },
          {
            "name": "cursor",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Cursor"
            }
          },
          {
            "name": "user_id",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "integer"
                },
                {
                  "type": "null"
                }
              ],
              "title": "User Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v2/filelib/{knowledge_id}": {
      "delete": {
        "tags": [
          "OpenAPI",
          "Knowledge"
        ],
        "summary": "Delete Knowledge Api",
        "description": "Delete a knowledge resource (F030, dispatch by row.type).\n\nKnowledge space (3) → ``KnowledgeSpaceService.delete_space`` (cascade child\nfiles/folders + ReBAC tuple cleanup + members). Knowledge base (0/1) →\n``KnowledgeService.delete_knowledge``.",
        "operationId": "delete_knowledge_api_api_v2_filelib__knowledge_id__delete",
        "parameters": [
          {
            "name": "knowledge_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Knowledge Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v2/filelib/clear/{knowledge_id}": {
      "delete": {
        "tags": [
          "OpenAPI",
          "Knowledge"
        ],
        "summary": "Clear Knowledge Files",
        "description": "Clear a knowledge resource's contents (F030, dispatch by row.type).\n\nKnowledge space (3) → ``KnowledgeSpaceService.clear_space`` (remove child\nfiles/folders + child tuples, keep the space). Knowledge base (0/1) →\n``KnowledgeService.delete_knowledge(only_clear=True)``.",
        "operationId": "clear_knowledge_files_api_v2_filelib_clear__knowledge_id__delete",
        "parameters": [
          {
            "name": "knowledge_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Knowledge Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v2/filelib/file/{knowledge_id}": {
      "post": {
        "tags": [
          "OpenAPI",
          "Knowledge"
        ],
        "summary": "Upload File",
        "description": "Upload a file to a knowledge resource (F030 facade, dispatch by row.type).\n\nKnowledge base (0/1) → existing parse/split/ingest pipeline (``parent_id``\nignored). Knowledge space (3) → ``KnowledgeSpaceService.add_file`` which\nnatively places the file under ``parent_id`` (must exist, else 18010).",
        "operationId": "upload_file_api_v2_filelib_file__knowledge_id__post",
        "parameters": [
          {
            "name": "knowledge_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Knowledge Id"
            }
          }
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/Body_upload_file_api_v2_filelib_file__knowledge_id__post"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v2/filelib/file/list": {
      "get": {
        "tags": [
          "OpenAPI",
          "Knowledge"
        ],
        "summary": "Get Filelist",
        "description": "List files of a knowledge resource (F030 cursor pagination, dispatch by row.type).\n\nKnowledge base (0/1) → flat cursor list (``aget_knowledge_files_cursor``,\n``parent_id`` ignored). Knowledge space (3) → hierarchical cursor list\n(``list_space_children``) under ``parent_id`` (root when omitted). ``user_id``\nscopes visibility to that user (AD-02). Returns ``PageInfiniteCursorData`` + ``writeable``.",
        "operationId": "get_filelist_api_v2_filelib_file_list_get",
        "parameters": [
          {
            "name": "knowledge_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Knowledge Id"
            }
          },
          {
            "name": "parent_id",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "integer"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Parent Id"
            }
          },
          {
            "name": "keyword",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "title": "Keyword"
            }
          },
          {
            "name": "status",
            "in": "query",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "integer"
              },
              "title": "Status"
            }
          },
          {
            "name": "page_size",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 10,
              "title": "Page Size"
            }
          },
          {
            "name": "cursor",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Cursor"
            }
          },
          {
            "name": "user_id",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "integer"
                },
                {
                  "type": "null"
                }
              ],
              "title": "User Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v2/filelib/retrieve": {
      "post": {
        "tags": [
          "OpenAPI",
          "Knowledge"
        ],
        "summary": "Retrieve Chunks",
        "description": "Retrieve top-k chunks across one or more knowledge bases (no LLM generation).\n\nDesigned for external retrieval-tool integrations (e.g. agents that bring\ntheir own LLM). F030: runs as the configured default operator by default;\nwhen ``req.user_id`` is set, retrieval is scoped to that user's visible\nresources/files (the \"代用户检索\" protocol F029 deferred). Per-knowledge-base\ntag filtering keeps the existing ``filters`` structure (no flat tags).",
        "operationId": "retrieve_chunks_api_v2_filelib_retrieve_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RetrieveReq"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
